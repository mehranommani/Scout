# ============================================================
# Copy this file to .env and fill in ALL values before running
# ============================================================

# ── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=change_me_strong_password
DATABASE_URL=postgresql://scout:change_me_strong_password@localhost:5432/scout

# ── Qdrant ───────────────────────────────────────────────────────────────────
QDRANT_HOST=localhost
QDRANT_PORT=6333

# ── Ollama ───────────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
LLM_MODEL=qwen2.5:14b
EMBEDDING_MODEL=nomic-embed-text

# ── Langfuse (started by docker compose) ─────────────────────────────────────
LANGFUSE_HOST=http://localhost:3001
LANGFUSE_DB_PASSWORD=change_me_langfuse_db_password

# Generate with: openssl rand -base64 32 | tr -d '\n'
LANGFUSE_NEXTAUTH_SECRET=change_me_min_32_chars_random_string

# Generate with: openssl rand -hex 16
LANGFUSE_SALT=change_me_random_salt_hex

# Generate with: openssl rand -hex 32
LANGFUSE_ENCRYPTION_KEY=change_me_64_char_hex_string

LANGFUSE_PUBLIC_KEY=pk-lf-change_me
LANGFUSE_SECRET_KEY=sk-lf-change_me

# Langfuse admin account — log in at http://localhost:3001
LANGFUSE_INIT_USER_EMAIL=admin@yourdomain.com
LANGFUSE_INIT_USER_PASSWORD=change_me_admin_password
LANGFUSE_INIT_USER_NAME=Admin

# ── Internal services (docker compose) ───────────────────────────────────────
REDIS_PASSWORD=change_me_redis_password
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=change_me_minio_password
CLICKHOUSE_PASSWORD=change_me_clickhouse_password

# ── Data source API keys ─────────────────────────────────────────────────────
# Leave blank to skip that source (DuckDuckGo + Wikidata always work without keys)
OPENCORPORATES_API_KEY=
CRUNCHBASE_API_KEY=
